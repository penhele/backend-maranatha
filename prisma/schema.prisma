generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Congregation {
  id    String   @id @default(uuid())
  name  String
  phone String
  birth DateTime

  regionId String
  region   Region @relation(fields: [regionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Region {
  id   String @id @default(uuid())
  name String

  Congregation Congregation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
