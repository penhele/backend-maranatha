generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Congregation {
  id    String   @id @default(uuid())
  name  String
  phone String
  birth DateTime

  regionId String
  region   Region @relation(fields: [regionId], references: [id])

  pelkatId String
  pelkat   Pelkat @relation(fields: [pelkatId], references: [id])

  leadership Leadership?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Region {
  id   String @id @default(uuid())
  name String

  congregations Congregation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pelkat {
  id          String @id @default(uuid())
  name        String
  description String

  congregations Congregation[]
  leaderships   Leadership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Leadership {
  id String @id @default(uuid())

  positionId String
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  congregationId String       @unique
  congregation   Congregation @relation(fields: [congregationId], references: [id], onDelete: Cascade)

  pelkatId String
  pelkat   Pelkat @relation(fields: [pelkatId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pelkatId, positionId])
}

model Position {
  id   String @id @default(uuid())
  name String

  Leadership Leadership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
